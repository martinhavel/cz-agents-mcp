# MCP audit wiring — fire-and-forget POST to the webapp audit endpoint.
# Both must be set; if either is missing, audit calls are silently skipped.

# Base URL of the cz-agents webapp (no trailing slash).
# Production: https://app.cz-agents.dev
MCP_AUDIT_URL=https://app.cz-agents.dev

# Shared secret; must match WEBAPP_INTERNAL_KEY in the webapp deployment.
# Generate: openssl rand -hex 32
MCP_AUDIT_KEY=
